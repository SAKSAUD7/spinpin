# SpinPin Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── API Configuration ────────────────────────────────────────────────────────
# URL of the Django backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Your public website URL (used in sitemap.xml, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://spinpin.co.uk

# ─── Google Analytics ─────────────────────────────────────────────────────────
# Get this from Google Analytics → Admin → Data Streams → Measurement ID
# Leave empty to disable GA tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Next.js ─────────────────────────────────────────────────────────────────
# Port for the dev server (default: 3000, but SpinPin uses 5000)
PORT=5000

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key for encrypting cookies/sessions (generate a random 32+ char string)
NEXTAUTH_SECRET=your-random-secret-here-min-32-chars

# ─── Optional: Email (if integrating SendGrid) ───────────────────────────────
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
# FROM_EMAIL=noreply@spinpin.co.uk

# ─── Optional: Stripe Payments ───────────────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
